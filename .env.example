# SMTP Ayarları (Gmail App Password önerilir)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hadibarisalim@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM_EMAIL=hadibarisalim@gmail.com
SMTP_FROM_NAME=Hadi Barışalım

# Sunucu
PORT=3000
NODE_ENV=production

# Veritabanı
MONGODB_URI=mongodb+srv://<kullanici_adi>:<sifre>@<cluster_adresi>.mongodb.net/hadibarisalim?retryWrites=true&w=majority
MONGODB_URI_FALLBACK=mongodb://<kullanici_adi>:<sifre>@<shard_adresleri>/hadibarisalim?ssl=true&replicaSet=...

# Deneme Modu (true = rate limiter KAPALI, false/tanımsız = rate limiter AKTİF)
# Production'da bu satırı kaldırın veya false yapın
# DENEME_MODU=true

# Migration (isteğe bağlı — sadece legacy data taşırken gerekli)
# MIGRATE_SECRET=guclu-rastgele-bir-anahtar-buraya
